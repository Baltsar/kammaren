# Telegram bot token för Watcher-boten — driver både:
#  • daglig delivery i agents/orchestrator/delivery.ts
#  • commands /status, /pause, /resume, /legal, /forget i
#    agents/orchestrator/bots/watcher-bot.ts
#  • välkomst-notisen från dashboard/app/api/onboard
# Skapa via @BotFather i Telegram (rekommenderas: @KammarenWatcherBot).
TELEGRAM_BOT_TOKEN=

# Telegram bot token för Verifier-boten — single-purpose bot som
# returnerar chat_id på /start. Driver agents/orchestrator/bots/
# verifier-bot.ts. SEPARAT bot från ovanstående (rekommenderas:
# @kammarenverifyBOT).
TELEGRAM_BOT_TOKEN_VERIFIER=

# GitHub Personal Access Token med `contents: write`-scope på
# Baltsar/kammaren. Används av dashboard/app/api/onboard/route.ts för
# att committa nya kund-profiler till vault/customers/. Sätts som
# Vercel environment variable; behövs lokalt bara om du testar
# onboard-API:t mot riktigt GitHub.
GITHUB_PAT=

# Override repo-target om dashboarden ska committa till en fork
# (default: Baltsar/kammaren@main).
# GITHUB_OWNER=Baltsar
# GITHUB_REPO=kammaren
# GITHUB_BRANCH=main

# LLM-tagging fallback för okand-events (agents/orchestrator/rules/llm-tagger.ts).
# Provider switchas via LLM_PROVIDER. Default: berget (EU-hosted, GDPR by design).
# Anthropic-clienten finns kvar för framtida fallback men används inte default.
LLM_PROVIDER=berget
LLM_MODEL=mistralai/Mistral-Small-3.2-24B-Instruct-2506

# Berget AI — OpenAI-kompatibel API hostad i EU. Hämta nyckel på https://www.berget.ai/.
BERGET_API_KEY=

# Anthropic — endast för LLM_PROVIDER=anthropic. Kvar för framtida fallback.
ANTHROPIC_API_KEY=
