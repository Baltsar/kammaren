{
  "name": "kammaren",
  "version": "0.1.0",
  "description": "Deterministisk skatteberäknings-kärna för svenska aktiebolag",
  "type": "module",
  "bin": {
    "zhc": "./dist/orchestrator/run.js"
  },
  "scripts": {
    "zhc": "tsx orchestrator/run.ts",
    "dev": "tsx orchestrator/run.ts run --dry-run",
    "simulate": "tsx orchestrator/run.ts simulate --month 2026-03 --dry-run",
    "simulate:interactive": "tsx orchestrator/run.ts simulate --month 2026-03 --interactive --dry-run",
    "dashboard": "cd dashboard && npm run dev",
    "test": "vitest run",
    "typecheck": "tsc --noEmit",
    "build": "tsc",
    "bot:telegram": "tsx src/adapters/telegram.ts",
    "chat": "tsx src/adapters/cli.ts"
  },
  "keywords": [
    "ai",
    "agents",
    "swedish",
    "ab",
    "compliance",
    "bookkeeping",
    "multi-agent"
  ],
  "license": "AGPL-3.0-or-later",
  "engines": {
    "node": ">=18.0.0"
  },
  "devDependencies": {
    "@types/node": "^25.3.3",
    "@vercel/node": "^5.7.4",
    "tsx": "^4.7.0",
    "typescript": "^5.4.0",
    "vitest": "^1.6.0"
  },
  "dependencies": {
    "@anthropic-ai/sdk": "^0.78.0",
    "@clack/prompts": "^0.7.0",
    "@upstash/ratelimit": "^2.0.5",
    "@upstash/redis": "^1.34.3",
    "chalk": "^5.6.2",
    "fast-xml-parser": "^5.7.2",
    "grammy": "^1.41.1",
    "iconv-lite": "^0.7.2",
    "ora": "^8.2.0"
  }
}
