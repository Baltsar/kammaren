{
  "compilerOptions": {
    "target": "ES2022",
    "module": "Node16",
    "moduleResolution": "Node16",
    "outDir": "./dist",
    "rootDir": ".",
    "strict": true,
    "esModuleInterop": true,
    "skipLibCheck": true,
    "forceConsistentCasingInFileNames": true,
    "resolveJsonModule": true,
    "declaration": true,
    "declarationMap": true,
    "sourceMap": true
  },
  "include": ["orchestrator/**/*.ts", "src/**/*.ts", "skills/**/*.ts", "constants/**/*.ts", "verify/**/*.ts", "api/**/*.ts"],
  "exclude": [
    "node_modules",
    "dist",
    "**/*.test.ts",
    "verify/golden-cases/year-guard.cases.ts",
    "orchestrator/sie4-safety.ts"
  ]
}
